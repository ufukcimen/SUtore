{
  "name": "sutore",
  "private": true,
  "version": "0.1.0",
  "bin": {
    "sutore": "scripts/sutore.mjs"
  },
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "start": "npm run dev",
    "sutore": "npm run dev",
    "dev": "concurrently --names \"API,WEB\" --prefix-colors \"cyan.bold,magenta.bold\" --kill-others-on-fail \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "node scripts/api-dev.mjs",
    "dev:web": "npm --workspace apps/web run dev -- --open",
    "build:web": "npm --workspace apps/web run build",
    "preview:web": "npm --workspace apps/web run preview",
    "test:web": "npm --workspace apps/web run test",
    "test:api": "node scripts/api-test.mjs",
    "setup": "node scripts/setup.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
