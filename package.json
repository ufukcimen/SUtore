{
  "name": "sutore",
  "private": true,
  "version": "0.1.0",
  "bin": {
    "sutore": "scripts/sutore"
  },
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "start": "npm run dev",
    "sutore": "npm run dev",
    "dev": "concurrently --names \"API,WEB\" --prefix-colors \"cyan.bold,magenta.bold\" --kill-others-on-fail \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd apps/api && .venv/bin/python -B -m uvicorn app.main:app --reload",
    "dev:web": "npm --workspace apps/web run dev -- --open",
    "build:web": "npm --workspace apps/web run build",
    "preview:web": "npm --workspace apps/web run preview",
    "test:web": "npm --workspace apps/web run test",
    "test:api": "cd apps/api && .venv/bin/python -m pytest",
    "setup": "npm install && cd apps/api && (test -d .venv || python3 -m venv .venv) && .venv/bin/pip install -e . && (test -f .env || cp .env.example .env)"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
